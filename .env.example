# ============================================================
# SYNAPSE DRIVE BOT — Environment configuration
# Copy to .env and fill in real values
# ============================================================

# -------- Discord --------
DISCORD_TOKEN=                       # Bot token z Discord Developer Portal
DISCORD_GUILD_ID=                    # ID Discord servera (Drive.sk)
DISCORD_LEADS_CHANNEL_ID=            # Kanál kam sa postnú lead embedy (napr. #leady-kristian)
DISCORD_KRISTIAN_USER_ID=            # Discord user ID Kristiána (pre @ping a permissions)
DISCORD_ADMIN_ROLE_ID=               # Role ID adminov (môžu meniť status leadu)

# -------- Supabase --------
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=                # Service role key (NIE anon key)

# -------- WhatsApp Cloud API (Meta) --------
WHATSAPP_PHONE_NUMBER_ID=            # Z Meta App > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=               # System User token (permanentný), nie dočasný
WHATSAPP_RECIPIENT_NUMBER=421900000000   # Kristiánovo číslo bez +
WHATSAPP_TEMPLATE_NAME=novy_lead     # Názov schváleného template
WHATSAPP_TEMPLATE_LANG=sk            # Jazyk template (sk alebo en)
WHATSAPP_API_VERSION=v21.0           # Graph API verzia

# -------- App settings --------
LOG_LEVEL=INFO                       # DEBUG / INFO / WARNING / ERROR
ENVIRONMENT=production               # development / production
CAR_PARSER_TIMEOUT=10                # Timeout v sekundách pre scraping
