# ---- Discord ----
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_LEASING_CHANNEL_ID=        # voliteľné — kanál kde /leasing funguje

# ---- Telegram (notifikácie Kristiánovi) ----
# 1. BotFather (@BotFather v Telegrame) → /newbot → token sem
TELEGRAM_BOT_TOKEN=
# 2. Kristián otvorí t.me/<bot_username> a klikne Start (DM)
# 3. https://api.telegram.org/bot<TOKEN>/getUpdates → skopíruj "chat":{"id":...}
TELEGRAM_CHAT_ID=

# ---- Google Sheets (evidencia pre Petra) ----
# Voliteľné: ak prázdne, zápis do Sheetu sa preskočí (pôjde len Telegram).
# 1. Google Cloud → service account → stiahni JSON kľúč do secrets/
# 2. Zdieľaj cieľový Sheet so service-account emailom (client_email z JSON) ako Editor
# 3. Sheet ID = časť URL medzi /d/ a /edit
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google-service-account.json

# ---- App ----
LOG_LEVEL=INFO
ENVIRONMENT=production
