# ---- Discord ----
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_LEASING_CHANNEL_ID=

# ---- Telegram ----
# 1. BotFather (@BotFather v Telegrame) → /newbot → token sem
TELEGRAM_BOT_TOKEN=
# 2. Kristián otvorí t.me/<bot_username> a klikne Start (DM)
#    ALEBO: vytvor group chat s botom + Kristiánom
# 3. Otvor https://api.telegram.org/bot<TOKEN>/getUpdates → skopíruj "chat":{"id":...}
#    DM = kladné číslo, group = záporné (často "-100...")
TELEGRAM_CHAT_ID=

# ---- App ----
LOG_LEVEL=INFO
ENVIRONMENT=production
